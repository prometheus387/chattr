# Copy this file to `.env` and fill in real values. `.env` is gitignored.
#
# Generate strong passwords with:
#   openssl rand -base64 24       # random password
#   openssl rand -base64 48       # 64-char random string (good for JWT keys)

# ---- Postgres ----
# The API's connection string is in appsettings.Development.json and
# currently mirrors whatever you put here. In production, set the
# backend's connection-string password via env var or secret store.
POSTGRES_PASSWORD=chattr

# ---- Cap (captcha service) ----
# Used to sign admin-API requests. Generate with: openssl rand -base64 32
CAP_ADMIN_KEY=cap-admin-token-rotate-me

# The SECRETKEY and SITEKEY are auto-generated by the Cap container on
# first run. After the first boot, copy them from the container logs:
#   docker compose logs cap | grep -i 'sitekey\|secretkey'
# then paste them here and in chattr_Frontend/.env.local.
CAP_SECRETKEY=cap-server-secret-rotate-me
CAP_SITEKEY=cap-site-key-rotate-me

# ---- Seq (structured logging) ----
# PBKDF2 hash of the initial admin password. To regenerate:
#   docker run --rm datalust/seq:latest hash-password 'MyNewPassword'
SEQ_FIRSTRUN_ADMINPASSWORDHASH=changeme-pbkdf2-hash

# Optional: the URL Seq advertises in API responses. Defaults to
# http://localhost in dev. Set this in production.
# SEQ_API_CANONICALURI=https://seq.example.com
