# Copy this file to `.env.local` and fill in real values.
# `.env.local` is gitignored.

# Server-only. Used by next.config.mjs to proxy /api/* requests to the
# .NET API. Never reaches the browser bundle.
#
#   Dev:      http://localhost:5147 (the API's default port)
#   Prod:     internal address of the API, e.g. http://api:8080 or
#             http://chattr-api.internal
INTERNAL_API_URL=http://localhost:5147

# If you wire Cap captcha into the auth forms, paste the SITEKEY the
# Cap container generated on first boot (see SETUP_BACKEND_DOCKER.md).
# Only the public sitekey belongs here — the SECRETKEY stays server-side.
NEXT_PUBLIC_CAP_SITEKEY=...